# --- Neon (PostgreSQL) ---
# Neon 콘솔의 Connection string을 그대로 붙여 넣습니다.
# 예: postgresql://neondb_owner:xxxx@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL=

# --- 공공데이터포털(data.go.kr) 인증키 ---
# https://www.data.go.kr 마이페이지 > 인증키 관리에서 발급
# 선거공약(15040587), 후보자(15000908), 당선인(15000864),
# 투·개표(15000900), 코드정보(15000897), 투표소(15000836) 6개 API에
# 활용신청 승인이 되어 있어야 합니다.
DATA_GO_KR_API_KEY_ENCODED=
DATA_GO_KR_API_KEY_DECODED=
